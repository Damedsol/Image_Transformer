# Configuración del servidor
PORT=3001
NODE_ENV=development
BACKEND_URL=

# Configuración de CORS
# URL del frontend desplegado (ej: https://tu-sitio.netlify.app)
# Para múltiples orígenes, separar por comas
CORS_ORIGIN=
CORS_ORIGINS=
# Permitir localhost en producción (útil para testing local)
ALLOW_LOCALHOST=false

# Configuración de logging (debug, info, warn, error)
LOG_LEVEL=info

# Configuración de límites de solicitudes
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_IMAGE_UPLOAD_WINDOW_MS=3600000
RATE_LIMIT_IMAGE_UPLOAD_MAX=20
DAILY_QUOTA_PER_IP=100

# Configuración de imágenes
# Tamaño máximo por archivo (5MB)
MAX_FILE_SIZE=5242880
# Número máximo de archivos por solicitud
MAX_FILES_PER_REQUEST=10
# Memoria máxima para procesamiento de Sharp (en MB)
SHARP_MEMORY_LIMIT=2048
# Concurrencia de hilos para Sharp
SHARP_CONCURRENCY=1
# Tiempo de limpieza de archivos temporales (en ms)
TEMP_FILES_CLEANUP_MS=300000
# Dimensiones máximas permitidas para imágenes (en px)
MAX_IMAGE_WIDTH=8000
MAX_IMAGE_HEIGHT=8000
# Tamaño máximo para el archivo ZIP resultante (en bytes)
MAX_ZIP_SIZE=50000000

# Configuración de seguridad avanzada
# Tiempo máximo de procesamiento por imagen (segundos)
IMAGE_PROCESSING_TIMEOUT=60
