{
  "name": "image-transformer-backend",
  "version": "1.1.9",
  "description": "Backend para convertir imágenes usando Sharp",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "test": "jest",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "archiver": "7.0.1",
    "cors": "2.8.6",
    "dotenv": "17.2.3",
    "express": "5.2.1",
    "express-rate-limit": "8.2.1",
    "helmet": "8.1.0",
    "multer": "2.0.2",
    "pino": "10.3.0",
    "sharp": "0.34.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/archiver": "7.0.0",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/multer": "2.0.0",
    "@types/node": "25.0.10",
    "@typescript-eslint/eslint-plugin": "8.53.1",
    "@typescript-eslint/parser": "8.53.1",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "nodemon": "3.1.11",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.1",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.53.1"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@^1.0.0": "1.1.12",
      "brace-expansion@^2.0.0": "2.0.2",
      "glob": ">=10.5.0",
      "jws": ">=3.2.3",
      "js-yaml": ">=4.1.1",
      "body-parser": ">=2.2.1"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
