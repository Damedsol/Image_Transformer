#!/bin/sh
# Run comprehensive checks before commit
echo "🔍 Running pre-commit checks..."
echo "📋 Checking code quality, formatting, and type safety..."

# Run TypeScript type checking first
echo "🔧 Running TypeScript type checking..."
pnpm type-check
if [ $? -ne 0 ]; then
    echo "❌ TypeScript type checking failed. Please fix type errors before committing."
    echo "💡 Check the TypeScript errors above and fix them."
    exit 1
fi
echo "✅ TypeScript type checking passed!"

# Run lint-staged for code quality and formatting
echo "🔧 Running lint and format checks on staged files..."
pnpm lint-staged

# Check if lint-staged succeeded
if [ $? -eq 0 ]; then
    echo "✅ All checks passed! Code is ready for commit."
    echo "🚀 Proceeding with commit..."
else
    echo "❌ Lint checks failed. Please fix the issues before committing."
    echo "💡 Run 'pnpm lint:fix' to automatically fix some issues."
    exit 1
fi 